#include <stdio.h>
int add(int num1 ,int num2);
void main ()
{
    int n1,n2;

    printf("Enter the first number :");
    scanf("%d",&n1);
    printf("Enter the second number :");
    scanf("%d",&n2);

    printf("The Sum of the two number is %d", add(n1,n2));


}
int add (int num1,int num2)
{
    int sum;

    sum = num1+num2;
    return sum;
   
}

----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* OUTPUT :
--------------------
