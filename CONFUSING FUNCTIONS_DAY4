******************************************************************************************************EXPLAINING THE FUNCTION WITH THE HELP OF ADDING TWO NUMBERS*********************************************************************************
// EXAMPLE FOR NO RETURN TYPE AND ALS0 NO ARGUMENTS
----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* PROGRAM CODE :
---------------------
#include <stdio.h>


void add();     ###### ----> FUNCTION DECLARATION
void main ()
{

    add();   ##########-----> FUNCTION CALLING
}
void add ()  #########------> FUNCTION DECLARATION
{
    int num1,num2,sum;

    printf("Enter the first number :");
    scanf("%d",&num1);
    printf("Enter the second number :");
    scanf("%d",&num2);

    sum = num1+num2;
    printf("The Sum of the two number is %d",sum);
}
----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* OUTPUT :
--------------------
Enter the first number :100
Enter the second number :150
The Sum of the two number is 250
