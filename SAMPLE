// TO CALCULATE THE GROSS AMOUNT FROM THE BASIC AMOUNT
---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* PROGRAM CODE :
-----------------------
#include<stdio.h>
int main()
{
    int da,hra,amount,gross;
    printf("Enter your basic salary :");
    scanf("%d",&amount);
    da = 40 * amount;
    hra = 20 * amount;
    gross = amount + da + hra;
    printf("The Gross salary is %d",gross);
    return 0;
}
---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* OUTPUT :
Enter your basic salary :20000
The Gross salary is 1220000
