// TO FIND THE SQUARE ROOT OF A GIVEN NUMBER 
----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* PROGRAM CODE :
---------------------
# include <stdio.h>
# include<math.h>
int main()
{

    int num,sqr,sqrt1;

    printf("Enter the number to perform the square root :");
    scanf("%d",&num);
    sqrt1=sqrt(num);
    printf("The Square root of the given number %d is %d",num,sqrt1);
    return 8;

}
