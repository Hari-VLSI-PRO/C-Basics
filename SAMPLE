// TO FIND THE PROFIT FOR THR MILK VENDOR
---------------------------------------------------------------------------------------------------------------------------------------------------------------------------
--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* PROGRAM CODE :
------------------------
#include<stdio.h>
int main()
{
    float originalcp = 3.25;
    float marketcp = 4.15;
    
    float sp,cp,profit;
    sp =  5 * marketcp;
    cp = 4 * originalcp;
    
    profit = sp - cp;
    printf("The gain for the milk vendor is %f",profit);
    return 0;
}
--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* OUTPUT :
-----------------------------
The gain for the milk vendor is 7.750000
