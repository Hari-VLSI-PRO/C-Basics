//TO FIND OUT THE MULTIPILICATION AND DIVISION OF TWO NUMBERS
--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* PROGRAM CODE :
---------------------------------
void main()
{
    int a,b,product,diff;
    
    printf("Enter two numbers");
    scanf("%d%d",&a,&b);
    
    product=a*b;
    diff=a/b;
    
    printf("%d*%d=%d %d/%d=%d",a,b,product,a,b,diff);
    
}
