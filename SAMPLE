//  TO FIND THE AREA AND PERIMETER OF AN RECTANGLE
--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* PROGRAM CODE :
-------------------
# include <stdio.h>
int main()
{

    int len,breadth,area,peri;

    printf("Enter the length of the rectangle :");
    scanf("%d",&len);
    printf("Enter the breadth of the rectangle :");
    scanf("%d",&breadth);
    area = len * breadth;
    peri = 2 * (len + breadth);
    printf("The Area of the rectangle is %d \n The Perimeter of the rectangle is %d",area,peri);

    return 8;

}
-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* OUTPUT :
--------------------
Enter the length of the rectangle :10
Enter the breadth of the rectangle :10
The Area of the rectangle is 100
 The Perimeter of the rectangle is 40
