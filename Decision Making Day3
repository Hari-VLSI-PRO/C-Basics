// TO CHECK WHETHER THE CANDIDATRE IS ELIGIBLE TO VOTING OR NOT
--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* PROGRAM CODE :
------------------
# include <stdio.h>

void main()
{
    int age;
    printf("Candidate Enter your age :");
    scanf("%d",&age);

    if (age >17)
    {
        printf("You are Eligible for Voting");
    }
    else
    {
        printf("OOPS !!!! You are not Eligible for voting ");
    }
}
